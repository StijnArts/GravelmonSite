{
  "name": "gravelmon-dynamodb-graph-nodejs",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js runtime contents for the DynamoDB graph Lambda layer.",
  "scripts": {
    "build": "rimraf dist && tsc && node scripts/build-layer.js && node scripts/create-lambda-layer.js",
    "create-layer": "node scripts/create-lambda-layer.js",
    "bootstrap": "rimraf dist && tsc && node scripts/build-layer.js && node scripts/create-lambda-layer.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand src/__tests__/dynamo.integration.test.ts",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.5.0",
    "archiver": "^6.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.358.0",
    "@aws-sdk/util-dynamodb": "^3.358.0"
  }
}
