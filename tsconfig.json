{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "dynamodb-graph/*": ["../gravelmon-dynamodb-graph/nodejs/dist/dynamodb-graph/*"],
      "dynamodb-graph": ["../gravelmon-dynamodb-graph/nodejs/dist/dynamodb-graph"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}